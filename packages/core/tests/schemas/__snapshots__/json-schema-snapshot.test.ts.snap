                          },
                          "reconnectMaxAttempts": {
                            "type": "number",
                            "minimum": 0,
                            "default": 10,
                            "description": "Maximum number of reconnection attempts"
                          },
                          "reconnectDelay": {
                            "type": "number",
                            "minimum": 100,
                            "default": 1000,
                            "description": "Initial delay in milliseconds before reconnecting"
                          },
                          "reconnectMaxDelay": {
                            "type": "number",
                            "minimum": 1000,
                            "default": 30000,
                            "description": "Maximum delay in milliseconds for exponential backoff"
                          },
                          "eventTypes": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            },
                            "description": "Event types to listen for (SSE only)"
