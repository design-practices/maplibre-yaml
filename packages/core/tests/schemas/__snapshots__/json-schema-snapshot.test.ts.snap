              },
              "blocks": {
                "type": "array",
                "items": {
                  "anyOf": [
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "content",
                          "description": "Block type"
                        },
                        "id": {
                          "type": "string",
                          "description": "Unique block identifier"
                        },
                        "className": {
                          "type": "string",
                          "description": "CSS class name for the block container"
                        },
                        "style": {
                          "type": "string",
                          "description": "Inline CSS styles for the block container"
                        },
                        "content": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "additionalProperties": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "str": {
                                    "type": "string",
                                    "description": "Static text string"
                                  },
                                  "property": {
                                    "type": "string",
                                    "description": "Dynamic property from context"
                                  },
                                  "else": {
                                    "type": "string",
                                    "description": "Fallback value if property missing"
                                  },
                                  "classList": {
                                    "anyOf": [
                                      {
                                        "type": "string"
                                      },
                                      {
                                        "type": "array",
                                        "items": {
                                          "type": "string"
                                        }
                                      }
                                    ],
                                    "description": "CSS class names (space-separated string or array)"
                                  },
                                  "id": {
                                    "type": "string",
                                    "description": "Element ID attribute"
                                  },
                                  "style": {
                                    "type": "string",
                                    "description": "Inline CSS styles"
                                  },
                                  "href": {
                                    "type": "string",
                                    "format": "uri",
                                    "description": "Link URL"
                                  },
                                  "target": {
                                    "type": "string",
                                    "description": "Link target (_blank, _self, _parent, _top)"
                                  },
                                  "src": {
                                    "type": "string",
                                    "format": "uri",
                                    "description": "Source URL for img or iframe"
                                  },
                                  "alt": {
                                    "type": "string",
                                    "description": "Alternative text for images"
                                  },
                                  "width": {
                                    "type": [
                                      "string",
                                      "number"
                                    ],
                                    "description": "Width (pixels or %)"
                                  },
                                  "height": {
                                    "type": [
                                      "string",
                                      "number"
                                    ],
                                    "description": "Height (pixels or %)"
                                  }
                                },
                                "additionalProperties": true,
                                "description": "Content element with styling and properties"
                              }
