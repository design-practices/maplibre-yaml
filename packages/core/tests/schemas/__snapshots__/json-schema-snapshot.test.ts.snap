                    },
                    {
                      "$ref": "#/$defs/scrollytelling/properties/config/properties/center/items/1"
                    }
                  ],
                  "description": "Bounding box as [west, south, east, north]"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "number"
                  }
                }
              ],
              "description": "Fit map to bounds"
            },
            "minZoom": {
              "type": "number",
              "minimum": 0,
              "maximum": 24,
              "description": "Minimum zoom level"
            },
            "maxZoom": {
