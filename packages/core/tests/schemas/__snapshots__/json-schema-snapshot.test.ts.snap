                },
                {
                  "type": "number",
                  "minimum": -90,
                  "maximum": 90,
                  "description": "Latitude in degrees (-90 to 90)"
                }
              ],
              "description": "Default center [lng, lat] for all maps"
            },
            "dataFetching": {
              "type": "object",
