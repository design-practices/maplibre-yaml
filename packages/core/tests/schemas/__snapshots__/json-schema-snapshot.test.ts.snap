                          "hybrid"
                        ],
                        "default": "runtime",
                        "description": "When to fetch data: runtime (default), build, or hybrid"
                      },
                      "stream": {
                        "type": "object",
                        "properties": {
                          "type": {
                            "type": "string",
                            "enum": [
