                  "default": "runtime",
                  "description": "Default fetch strategy"
                },
                "timeout": {
                  "type": "number",
                  "minimum": 1000,
                  "default": 30000,
                  "description": "Default timeout in milliseconds"
                },
                "retryAttempts": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 3,
                  "description": "Default retry attempts"
                }
              },
              "additionalProperties": false,
              "description": "Data fetching configuration",
              "patternProperties": {
                "^x-": {}
              }
