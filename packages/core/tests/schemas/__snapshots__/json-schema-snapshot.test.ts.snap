"{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://docs.maplibre-yaml.org/schema/latest/any.schema.json",
  "title": "maplibre-yaml document (any block or root)",
  "description": "Any maplibre-yaml document: a \`type: map\` block, a \`type: scrollytelling\` block, or a \`pages:\` root document. Mirrors the \`safeParseAny\` dispatcher used by <ml-map> and \`mlym validate\`.",
  "$ref": "#/$defs/any",
  "$defs": {
    "any": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "map",
              "description": "Block type"
            },
            "id": {
              "type": "string",
              "description": "Unique block identifier"
            },
            "className": {
              "type": "string",
              "description": "CSS class name for container"
            },
            "style": {
              "type": "string",
              "description": "Inline CSS styles for container"
            },
            "config": {
              "type": "object",
              "properties": {
                "center": {
                  "type": "array",
                  "minItems": 2,
                  "maxItems": 2,
                  "items": [
                    {
                      "type": "number",
                      "minimum": -180,
                      "maximum": 180,
                      "description": "Longitude in degrees (-180 to 180)"
                    },
                    {
                      "type": "number",
                      "minimum": -90,
                      "maximum": 90,
                      "description": "Latitude in degrees (-90 to 90)"
                    }
                  ],
                  "description": "Initial map center [longitude, latitude]"
                },
                "zoom": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 24,
                  "description": "Initial zoom level (0-24)"
                },
                "mapStyle": {
                  "anyOf": [
                    {
                      "type": "string",
                      "format": "uri"
                    },
                    {}
                  ],
                  "description": "MapLibre style URL or style object. Optional when global config.defaultMapStyle is set."
                },
                "pitch": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 85,
                  "default": 0,
                  "description": "Camera pitch angle in degrees (0-85)"
                },
                "bearing": {
                  "type": "number",
                  "minimum": -180,
                  "maximum": 180,
                  "default": 0,
                  "description": "Camera bearing (rotation) in degrees (-180 to 180)"
                },
                "bounds": {
                  "anyOf": [
                    {
                      "type": "array",
                      "minItems": 4,
                      "maxItems": 4,
                      "items": [
                        {
                          "$ref": "#/$defs/any/oneOf/0/properties/config/properties/center/items/0"
                        },
                        {
                          "$ref": "#/$defs/any/oneOf/0/properties/config/properties/center/items/1"
                        },
                        {
                          "$ref": "#/$defs/any/oneOf/0/properties/config/properties/center/items/0"
                        },
                        {
                          "$ref": "#/$defs/any/oneOf/0/properties/config/properties/center/items/1"
                        }
                      ],
                      "description": "Bounding box as [west, south, east, north]"
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "number"
                      }
                    }
                  ],
                  "description": "Fit map to bounds"
                },
                "minZoom": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 24,
                  "description": "Minimum zoom level"
                },
                "maxZoom": {
                  "$ref": "#/$defs/any/oneOf/0/properties/config/properties/minZoom",
                  "description": "Maximum zoom level"
                },
                "minPitch": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 85,
                  "description": "Minimum pitch"
                },
                "maxPitch": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 85,
                  "description": "Maximum pitch"
                },
                "maxBounds": {
                  "$ref": "#/$defs/any/oneOf/0/properties/config/properties/bounds/anyOf/0",
                  "description": "Maximum geographic bounds"
                },
                "interactive": {
                  "type": "boolean",
                  "default": true,
                  "description": "Enable map interaction"
                },
                "scrollZoom": {
                  "type": "boolean",
                  "description": "Enable scroll to zoom"
                },
                "boxZoom": {
                  "type": "boolean",
                  "description": "Enable box zoom (shift+drag)"
                },
                "dragRotate": {
                  "type": "boolean",
                  "description": "Enable drag to rotate"
                },
                "dragPan": {
                  "type": "boolean",
                  "description": "Enable drag to pan"
                },
                "keyboard": {
                  "type": "boolean",
                  "description": "Enable keyboard shortcuts"
                },
                "doubleClickZoom": {
                  "type": "boolean",
                  "description": "Enable double-click zoom"
                },
                "touchZoomRotate": {
                  "type": "boolean",
                  "description": "Enable touch zoom/rotate"
                },
                "touchPitch": {
                  "type": "boolean",
                  "description": "Enable touch pitch"
                },
                "hash": {
                  "type": "boolean",
                  "description": "Sync map state with URL hash"
                },
                "attributionControl": {
                  "type": "boolean",
                  "description": "Show attribution control"
                },
                "logoPosition": {
                  "type": "string",
                  "enum": [
                    "top-left",
                    "top-right",
                    "bottom-left",
                    "bottom-right"
                  ],
                  "description": "MapLibre logo position"
                },
                "fadeDuration": {
                  "type": "number",
                  "description": "Fade duration in milliseconds"
                },
                "crossSourceCollisions": {
                  "type": "boolean",
                  "description": "Check for cross-source collisions"
                },
                "antialias": {
                  "type": "boolean",
                  "description": "Enable antialiasing"
                },
                "refreshExpiredTiles": {
                  "type": "boolean",
                  "description": "Refresh expired tiles"
                },
                "renderWorldCopies": {
                  "type": "boolean",
                  "description": "Render multiple world copies"
                },
                "locale": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  },
                  "description": "Localization strings"
                },
                "maxTileCacheSize": {
                  "type": "number",
                  "description": "Maximum tiles to cache"
                },
                "localIdeographFontFamily": {
                  "type": "string",
                  "description": "Font for CJK characters"
                },
                "trackResize": {
                  "type": "boolean",
                  "description": "Track container resize"
                },
                "preserveDrawingBuffer": {
                  "type": "boolean",
                  "description": "Preserve drawing buffer"
                },
                "failIfMajorPerformanceCaveat": {
                  "type": "boolean",
                  "description": "Fail if major performance caveat"
                }
              },
              "required": [
                "center",
                "zoom"
              ],
              "additionalProperties": true,
              "description": "Map configuration"
            },
            "sources": {
              "type": "object",
              "additionalProperties": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string",
                        "const": "geojson",
