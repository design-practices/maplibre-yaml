                  },
                  {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "Unique layer identifier"
                      },
                      "type": {
                        "type": "string",
                        "const": "background",
                        "description": "Layer type"
                      },
                      "paint": {
                        "type": "object",
                        "properties": {
                          "background-color": {
                            "$ref": "#/$defs/scrollytelling/properties/layers/items/anyOf/0/anyOf/0/properties/paint/properties/circle-color",
                            "description": "Color value or MapLibre expression"
                          },
                          "background-pattern": {
                            "type": "string"
                          },
                          "background-opacity": {
                            "$ref": "#/$defs/scrollytelling/properties/layers/items/anyOf/0/anyOf/0/properties/paint/properties/circle-radius",
                            "description": "Number value or MapLibre expression"
                          }
                        },
                        "additionalProperties": true,
                        "description": "Background paint properties"
                      },
                      "layout": {
                        "type": "object",
                        "properties": {},
                        "additionalProperties": true,
                        "description": "Background layout properties"
                      },
                      "metadata": {
                        "type": "object",
                        "additionalProperties": {},
                        "description": "Custom metadata"
                      }
                    },
                    "required": [
                      "id",
                      "type"
                    ],
                    "additionalProperties": true
                  }
                ]
              },
              {
                "type": "object",
                "properties": {
                  "$ref": {
                    "type": "string",
                    "description": "Reference to global layer (e.g., \\"#/layers/bikeLayer\\")"
                  }
                },
                "required": [
                  "$ref"
                ],
                "additionalProperties": false,
                "description": "Layer reference",
                "patternProperties": {
                  "^x-": {}
                }
              }
            ]
          },
          "default": [],
          "description": "Persistent layers (visible throughout story)"
        },
        "chapters": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique chapter identifier"
              },
              "title": {
                "type": "string",
                "description": "Chapter title"
              },
              "center": {
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "items": [
                  {
                    "$ref": "#/$defs/scrollytelling/properties/config/properties/center/items/0"
                  },
                  {
                    "$ref": "#/$defs/scrollytelling/properties/config/properties/center/items/1"
                  }
                ],
                "description": "Map center [longitude, latitude]"
              },
              "zoom": {
                "type": "number",
                "description": "Zoom level"
              },
              "description": {
                "type": "string",
                "description": "Chapter description (HTML/markdown supported)"
              },
              "image": {
                "type": "string",
                "format": "uri",
                "description": "Hero image URL"
              },
              "video": {
                "type": "string",
                "format": "uri",
                "description": "Video URL"
              },
              "pitch": {
                "type": "number",
                "minimum": 0,
                "maximum": 85,
                "default": 0,
                "description": "Camera pitch angle (0-85)"
              },
              "bearing": {
                "type": "number",
                "minimum": -180,
                "maximum": 180,
                "default": 0,
                "description": "Camera bearing (-180 to 180)"
              },
              "speed": {
                "type": "number",
                "minimum": 0,
                "maximum": 2,
                "default": 0.6,
                "description": "Animation speed multiplier (0-2)"
              },
              "curve": {
                "type": "number",
                "minimum": 0,
                "maximum": 2,
                "default": 1,
                "description": "Animation curve (0=linear, 1=default, 2=steep)"
              },
              "animation": {
                "type": "string",
                "enum": [
                  "flyTo",
                  "easeTo",
                  "jumpTo"
                ],
                "default": "flyTo",
                "description": "Animation type"
              },
              "rotateAnimation": {
                "type": "boolean",
                "description": "Enable continuous rotation animation"
              },
              "spinGlobe": {
                "type": "boolean",
                "description": "Spin globe animation (for low zoom levels)"
              },
              "alignment": {
                "type": "string",
                "enum": [
                  "left",
                  "right",
                  "center",
                  "full"
                ],
                "default": "center",
                "description": "Content alignment"
              },
              "hidden": {
                "type": "boolean",
                "default": false,
                "description": "Hide chapter content (map-only)"
              },
              "layers": {
                "type": "object",
                "properties": {
                  "show": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "default": [],
                    "description": "Layer IDs to show"
                  },
                  "hide": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "default": [],
                    "description": "Layer IDs to hide"
                  }
                },
                "additionalProperties": false,
                "description": "Layer visibility control",
                "patternProperties": {
                  "^x-": {}
                }
              },
              "onChapterEnter": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "action": {
                      "type": "string",
                      "enum": [
                        "setFilter",
                        "setPaintProperty",
                        "setLayoutProperty",
                        "flyTo",
                        "easeTo",
                        "fitBounds",
                        "custom"
                      ],
                      "description": "Action type"
                    },
                    "layer": {
                      "type": "string",
                      "description": "Target layer ID"
                    },
                    "property": {
                      "type": "string",
                      "description": "Property name (for setPaintProperty/setLayoutProperty)"
                    },
                    "value": {
                      "description": "Property value"
                    },
                    "filter": {
                      "anyOf": [
                        {
                          "$ref": "#/$defs/scrollytelling/properties/layers/items/anyOf/0/anyOf/0/properties/filter"
                        },
                        {
                          "type": "null"
                        }
                      ],
                      "description": "Filter expression (for setFilter, null to clear)"
                    },
                    "bounds": {
                      "type": "array",
                      "items": {
                        "type": "number"
                      },
                      "description": "Bounds array (for fitBounds)"
                    },
                    "options": {
                      "type": "object",
                      "additionalProperties": {},
                      "description": "Additional options"
                    }
                  },
                  "required": [
                    "action"
                  ],
                  "additionalProperties": false,
                  "description": "Chapter action for map state changes",
                  "patternProperties": {
                    "^x-": {}
                  }
                },
                "default": [],
                "description": "Actions when entering chapter"
              },
              "onChapterExit": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/scrollytelling/properties/chapters/items/properties/onChapterEnter/items"
                },
                "default": [],
                "description": "Actions when exiting chapter"
              },
              "callback": {
                "type": "string",
                "description": "Custom callback function name"
              }
            },
            "required": [
              "id",
              "title",
              "center",
              "zoom"
            ],
            "additionalProperties": false,
            "description": "Scrollytelling chapter",
            "patternProperties": {
              "^x-": {}
            }
          },
          "minItems": 1,
          "description": "Story chapters"
        },
        "footer": {
          "type": "string",
          "description": "Footer content (HTML)"
        }
      },
      "required": [
        "type",
        "id",
        "config",
        "chapters"
      ],
      "additionalProperties": false,
      "description": "Scrollytelling block for narrative map stories",
      "patternProperties": {
        "^x-": {}
      }
    }
  }
}
"
`;
