---
import "../styles/global.css";

interface Props {
  title?: string;
}
const { title = "@maplibre-yaml/astro — minimal example" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href="/" class="brand">@maplibre-yaml/astro — minimal example</a>
        <a href="/showcase">Showcase</a>
        <a href="/poas/sample">Content collection example</a>
      </nav>
    </header>
    <slot />
  </body>
</html>
